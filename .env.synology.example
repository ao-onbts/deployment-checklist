# ── Image ──────────────────────────────────────────────────────────────────────
APP_IMAGE=ghcr.io/ao-onbts/deployment-checklist
IMAGE_TAG=latest

# ── Port ───────────────────────────────────────────────────────────────────────
# This is the port Synology exposes on the host.
# Configure your reverse proxy: deployment.granas.de → http://localhost:8090
APP_PORT=8090

# ── GitHub Container Registry credentials ─────────────────────────────────────
# Used by:
#   publish_ghcr.ps1  — to log in locally and push the image  (needs write:packages)
#   deploy_synology.ps1 — to log in on the NAS and pull the image (read:packages is enough)
#
# Create a Classic PAT at https://github.com/settings/tokens
# Required scopes: write:packages  (includes read:packages and delete:packages)
GHCR_USER=ao-onbts
GHCR_PAT=ghp_your_token_here
